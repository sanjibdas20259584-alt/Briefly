# ===== Supabase =====
# From your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# SERVICE ROLE — KEEP SECRET. Used server-only for admin work.
# Never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===== App =====
# Absolute base URL. Used for portal links and emails.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===== Cron protection (optional) =====
# Set this and the /api/reminders/send route will require a Bearer token.
CRON_SECRET=

# ===== Telegram webhook secret (optional) =====
# If set, Telegram will include this in x-telegram-bot-api-secret-token header.
TELEGRAM_WEBHOOK_SECRET=

# ===== Google Drive OAuth2 (required for Drive integration) =====
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add http://localhost:3000/api/google/callback as Authorized redirect URI
# 4. Enable the Google Drive API in the project
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback

# ===== Encryption =====
# 32-byte key, base64-encoded. Used to encrypt provider API keys and the
# Telegram bot token before they are stored in the database.
# Generate locally with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=replace-with-base64-encoded-32-bytes

# ===== Optional: local OpenAI-compatible LLM =====
# Used by Settings "ensure local provider" / scripts. Prefer adding via UI.
# LOCAL_LLM_BASE_URL=http://localhost:20128/v1
# LOCAL_LLM_API_KEY=sk-your-key
# LOCAL_LLM_MODEL=local-model
# LOCAL_LLM_NAME=your_local_llm_name_here